# fast-classifier reads credentials from the environment ONLY — never from config files.
# The two tokens are DISTINCT credentials (a JMAP API token does not work against the
# MCP endpoint and vice versa). Create them at:
#   Fastmail -> Settings -> Privacy & Security -> Integrations -> API tokens
# Scope the JMAP token to Mail read + write only (no contacts/calendars/files, no
# sending). Use a read-only token if you only run `analyze` / `plan`.

# JMAP API token (default transport, --provider jmap)
FASTMAIL_API_TOKEN=

# Fastmail official MCP endpoint token (--provider mcp)
FASTMAIL_MCP_TOKEN=

# never commit .env
